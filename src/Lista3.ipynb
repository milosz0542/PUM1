    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"data class Point(var x: Int, var y: Int) {\\n\",\n",
    "    \"    operator fun plus(other: Point): Point = Point(x + other.x, y + other.y)\\n\",\n",
    "    \"    operator fun minus(other: Point): Point = Point(x - other.x, y - other.y)\\n\",\n",
    "    \"    operator fun times(other: Point): Point = Point(x * other.x, y * other.y)\\n\",\n",
    "    \"    operator fun not(): Point = Point(-x, -y)\\n\",\n",
    "    \"    operator fun inc(): Point = Point(x + 1, y + 1)\\n\",\n",
    "    \"    operator fun dec(): Point = Point(x - 1, y - 1)\\n\",\n",
    "    \"    operator fun plusAssign(num: Int) {\\n\",\n",
    "    \"        this.x += num\\n\",\n",
    "    \"        this.y += num\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"var p1 = Point(1, 1)\\n\",\n",
    "    \"var p2 = Point(2, 2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"println(p1 + p2)\\n\",\n",
    "    \"println(p1 - p2)\\n\",\n",
    "    \"println(p1 * p2)\\n\",\n",
    "    \"println(++p1)\\n\",\n",
    "    \"println(--p1)\\n\",\n",
