    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"data class StudentScore(val name: String, val subject: String, val score: Int)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fun analyzeResults(lst: List<StudentScore>): Triple<Map<String, List<StudentScore>>, List<StudentScore>, List<String>> {\\n\",\n",
    "    \"    val passedBySubject = lst.groupBy { it.subject }.mapValues { it.value.filter { it.score >= 50 } }\\n\",\n",
    "    \"    val failed = lst.filter { it.score < 50 }\\n\",\n",
    "    \"    val subjectsAllPassed = lst.groupBy { it.subject }.filter { it.value.all { student -> student.score >= 60 } }.keys.toList()\\n\",\n",
    "    \"    return Triple(\\n\",\n",
    "    \"        passedBySubject,\\n\",\n",
    "    \"        failed,\\n\",\n",
    "    \"        subjectsAllPassed\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"val students = listOf(\\n\",\n",
    "    \"    StudentScore(\\\"Alice\\\", \\\"Math\\\", 78),\\n\",\n",
    "    \"    StudentScore(\\\"Bob\\\", \\\"Math\\\", 45),\\n\",\n",
    "    \"    StudentScore(\\\"Charlie\\\", \\\"Physics\\\", 92),\\n\",\n",
    "    \"    StudentScore(\\\"Dave\\\", \\\"Physics\\\", 55),\\n\",\n",
    "    \"    StudentScore(\\\"Eve\\\", \\\"Physics\\\", 40),\\n\",\n",
    "    \"    StudentScore(\\\"Frank\\\", \\\"CS\\\", 60),\\n\",\n",
    "    \"    StudentScore(\\\"Grace\\\", \\\"CS\\\", 80),\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"val (passedBySubject, failed, subjectsAllPassed) = analyzeResults(students)\\n\",\n",
    "    \"\\n\",\n",
    "    \"println(\\\"Zdani studenci według przedmiotów: $passedBySubject\\\")\\n\",\n",
    "    \"println(\\\"Niezdani studenci: $failed\\\")\\n\",\n",
    "    \"println(\\\"Przedmioty, w których wszyscy zdali: $subjectsAllPassed\\\")\"\n",
    "   ],\n",
